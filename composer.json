{
    "name": "smronju/laravel-sslcommerz",
    "description": "Laravel SSLCommerz is a super easy package to integrate SSLCommerz on Laravel websites.",
    "keywords": [
        "laravel",
        "sslcommerz",
        "payment-gateway",
        "laravel-sslcommerz"
    ],
    "homepage": "https://github.com/smronju/laravel-sslcommerz",
    "license": "MIT",
    "authors": [
        {
            "name": "Mohammad Shoriful Islam Ronju",
            "email": "smronju@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2||^8.3||^8.4",
        "spatie/laravel-package-tools": "^1.16",
        "illuminate/contracts": "^12.0||^13.0",
        "illuminate/support": "^12.0||^13.0",
        "illuminate/http": "^12.0||^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.14",
        "nunomaduro/collision": "^8.1||^9.0",
        "orchestra/testbench": "^10.0.0||^11.0.0",
        "pestphp/pest": "^3.0||^4.0",
        "pestphp/pest-plugin-arch": "^3.0||^4.0",
        "pestphp/pest-plugin-laravel": "^3.0||^4.0"
    },
    "autoload": {
        "psr-4": {
            "Smronju\\Sslcommerz\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Smronju\\Sslcommerz\\Tests\\": "tests/",
            "Workbench\\App\\": "workbench/app/"
        }
    },
    "scripts": {
        "post-autoload-dump": "@composer run prepare",
        "clear": "@php vendor/bin/testbench package:purge-laravel-sslcommerz --ansi",
        "prepare": "@php vendor/bin/testbench package:discover --ansi",
        "build": [
            "@composer run prepare",
            "@php vendor/bin/testbench workbench:build --ansi"
        ],
        "start": [
            "Composer\\Config::disableProcessTimeout",
            "@composer run build",
            "@php vendor/bin/testbench serve"
        ],
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/pest",
        "test-coverage": "vendor/bin/pest --coverage",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Smronju\\Sslcommerz\\SslcommerzServiceProvider"
            ],
            "aliases": {
                "Sslcommerz": "Smronju\\Sslcommerz\\Facades\\Sslcommerz"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
